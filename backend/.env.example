# Server
PORT=8080
FRONTEND_URL=http://localhost:4567

# Database (required)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sidney
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/sidney

# Supabase (for JWT verification)
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_JWT_SECRET=
SUPABASE_PUBLISHABLE_KEY=

# AI / Research
GEMINI_API_KEY=
GEMINI_MODEL_NAME=google_genai:gemini-3-flash-preview
ASKNEWS_API_KEY=

# Google Cloud Storage
GCS_BUCKET=
GOOGLE_APPLICATION_CREDENTIALS=application_default_credentials.json

# LangSmith tracing (optional)
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_PROJECT=
LANGSMITH_API_KEY=

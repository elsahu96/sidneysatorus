# Server
PORT=8080
FRONTEND_URL=http://localhost:4567

# Database — Cloud SQL (PostgreSQL on GCP)
# Local:     postgresql://postgres:postgres@localhost:5432/sidney
# Cloud Run: postgresql://USER:PASSWORD@/DB_NAME?host=/cloudsql/PROJECT:REGION:INSTANCE
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sidney

# Firebase (auth — backend token verification)
GOOGLE_CLOUD_PROJECT=
GOOGLE_APPLICATION_CREDENTIALS=service-account.json

# AI / Research
GEMINI_API_KEY=
GEMINI_MODEL_NAME=google_genai:gemini-3-flash-preview
ASKNEWS_API_KEY=

# Google Cloud Storage
GCS_BUCKET=
STORAGE_BACKEND=gcs

# LangSmith tracing (optional)
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_PROJECT=
LANGSMITH_API_KEY=

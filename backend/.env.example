# Server
PORT=8080
FRONTEND_URL=http://localhost:4567


DATABASE_URL=postgresql://postgres:postgres@localhost:8888/sidney

# Firebase (auth — backend token verification)
GOOGLE_CLOUD_PROJECT=
GOOGLE_APPLICATION_CREDENTIALS=service-account.json

# AI / Research
GEMINI_API_KEY=
GEMINI_MODEL_NAME=google_genai:gemini-3.1-pro
ASKNEWS_API_KEY=
# Model used for the writer agent. Set to a lighter/faster model than ANTHROPIC_MODEL_NAME
# (e.g. claude-haiku-4-6) to cut report generation time significantly.
# Defaults to ANTHROPIC_MODEL_NAME if not set.
WRITER_MODEL_NAME=claude-haiku-4-5

# Google Cloud Storage
GCS_BUCKET=
STORAGE_BACKEND=gcs

# Vector DB (Qdrant)
# QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=

# Search (Elasticsearch)
# ELASTICSEARCH_URL=http://localhost:9200
# ELASTICSEARCH_API_KEY=

# Cache (Redis)
# REDIS_URL=redis://localhost:6379

# LangSmith tracing (optional)
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_PROJECT=
LANGSMITH_API_KEY=

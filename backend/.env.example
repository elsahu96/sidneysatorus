PORT=8080
FRONTEND_URL=http://localhost:4567

# Cloud SQL (PostgreSQL on GCP)
# Format: postgresql://USER:PASSWORD@INSTANCE_IP:5432/DB_NAME
# For Cloud Run use Unix socket: postgresql://USER:PASSWORD@/DB_NAME?host=/cloudsql/PROJECT:REGION:INSTANCE

DATABASE_URL=
# Vertex AI
VERTEX_PROJECT=
VERTEX_LOCATION=
GEMINI_API_KEY=
# MODELS
CLAUDE_OPUS_4_6=claude-opus-4-6
CLAUDE_HAIKU_4_5=claude-haiku-4-6
GEMINI_3_1_PRO_PREVIEW=google_genai:gemini-3.1-pro-preview
# asknews
ASKNEWS_API_KEY=
# storage (path is relative to backend/ when running from backend)
GOOGLE_CLOUD_PROJECT=satorus-sidney-dev
GOOGLE_APPLICATION_CREDENTIALS=service-account.json
STORAGE_BACKEND=gcs                                       
GCS_BUCKET=sidney-dev                                             
# LangSmith tracing
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
